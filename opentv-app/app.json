{
  "expo": {
    "name": "OpenTv",
    "slug": "opentv",
    "version": "1.4.0",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "opentvplayer",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "jsEngine": "hermes",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.opentv.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#050505",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.opentv.app",
      "jsEngine": "hermes"
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "@react-native-tvos/config-tv",
        {
          "isTV": true,
          "androidTVBanner": "./assets/images/android-tv-banner.png"
        }
      ],
      [
        "./plugins/withNetworkSecurityConfig",
        {}
      ],
      [
        "./modules/tv-channel/plugin"
      ],
      [
        "./modules/tv-player/plugin"
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 250,
          "resizeMode": "contain",
          "backgroundColor": "#000000",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-web-browser",
      [
        "expo-screen-orientation",
        {
          "initialOrientation": "DEFAULT"
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "bc49615e-a9b2-42ba-886e-255e2a2190d0"
      }
    },
    "owner": "ssjoy43"
  }
}
