<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

  <!--
    TvPlayerService keeps the ExoPlayer MediaSession alive when the user
    navigates to the Android TV launcher, enabling background audio.
    foregroundServiceType="mediaPlayback" is required on API 29+ for
    foreground service media playback.
  -->
  <application>
    <service
      android:name="expo.modules.tvplayer.TvPlayerService"
      android:exported="true"
      android:foregroundServiceType="mediaPlayback">
      <intent-filter>
        <action android:name="androidx.media3.session.MediaSessionService" />
      </intent-filter>
    </service>
  </application>

  <!-- Required for foreground media service on Android 9+ -->
  <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
  <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
  <!-- Required to post the playback notification on Android 13+ (API 33) -->
  <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

</manifest>
